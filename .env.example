VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenAI API key — this is NOT read from local .env files.
# It must be stored as a Supabase secret so it is never exposed to the browser.
# Set it once via the Supabase CLI:
#   supabase secrets set OPENAI_API_KEY=sk-...
# It is used exclusively by the openai-classify Edge Function.
# OPENAI_API_KEY=sk-your-openai-api-key-here
